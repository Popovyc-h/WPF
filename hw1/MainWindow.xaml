<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Потоки" Height="450" Width="600">

    <StackPanel Margin="10">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Від:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtFrom" Width="80" Margin="0,0,10,0"/>
            <TextBlock Text="До:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtTo" Width="80"/>
        </StackPanel>

        <TextBlock Text="Прості числа:" Margin="0,0,0,5"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <Button x:Name="btnStart" Content="Старт" Width="80" Margin="0,0,5,0" Click="btnStart_Click"/>
            <Button x:Name="btnStop" Content="Стоп" Width="80" Margin="0,0,5,0" Click="btnStop_Click"/>
            <Button x:Name="btnPrimePause" Content="Пауза" Width="80" Margin="0,0,5,0" Click="btnPrimePause_Click"/>
            <Button x:Name="btnPrimeResume" Content="Відновити" Width="80" Click="btnPrimeResume_Click"/>
        </StackPanel>
        <ListBox x:Name="lstPrimes" Height="80" Margin="0,0,0,10"/>

        <TextBlock Text="Фібоначчі числа:" Margin="0,0,0,5"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <Button x:Name="btnFibonacci" Content="Старт" Width="80" Margin="0,0,5,0" Click="btnFibonacci_Click"/>
            <Button x:Name="btnFibonacciStop" Content="Стоп" Width="80" Margin="0,0,5,0" Click="btnFibonacci_Stop"/>
            <Button x:Name="btnFibonacciPause" Content="Пауза" Width="80" Margin="0,0,5,0" Click="btnFibonacciPause_Click"/>
            <Button x:Name="btnFibonacciResume" Content="Відновити" Width="80" Click="btnFibonacciResume_Click"/>
        </StackPanel>
        <ListBox x:Name="Fibonacci" Height="80"/>

    </StackPanel>
</Window>
