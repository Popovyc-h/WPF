<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Потоки" Height="400" Width="600">

    <StackPanel Margin="10">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Від:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtFrom" Width="80" Margin="0,0,10,0"/>
            <TextBlock Text="До:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtTo" Width="80"/>
        </StackPanel>

        <Button x:Name="btnStart" Content="Старт" Width="100"
                HorizontalAlignment="Left" Click="btnStart_Click"/>

        <Button x:Name="btnStop" Content="Стоп" Width="100"
                HorizontalAlignment="Left" Click="btnStop_Click"/>

        <TextBlock Text="Прості числа:" Margin="0,10,0,5"/>
        <ListBox x:Name="lstPrimes" Height="80"/>

        <Button x:Name="btnFibonacci" Content="Старт" Width="100"
        HorizontalAlignment="Left" Click="btnFibonacci_Click"/>

        <Button x:Name="btnFibonacci_Stop" Content="Стоп" Width="100"
                HorizontalAlignment="Left" Click="btnFibonacciStop"/>
        
        <TextBlock Text="Фібоначчі числа:"></TextBlock>
        <ListBox x:Name="Fibonacci" Height="80"></ListBox>

    </StackPanel>
</Window>