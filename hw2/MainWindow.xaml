<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="625" Width="800">

    <StackPanel>
        
        <StackPanel Orientation="Horizontal" Margin="5,5,0,10">
            <TextBlock Text="Кількість прогрес-барів:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtCount" Width="80" Margin="0,0,10,0" TextChanged="txtCount_TextChanged"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="5,0,0,5">
            <Button x:Name="btnStart" Content="Старт" Width="80" Margin="0,0,5,0" Click="btnStart_Click"/>
        </StackPanel>

        <TextBlock Text="ProgressBar:" Margin="0,0,0,5"/>
        <ScrollViewer Height="150">
            <StackPanel x:Name="progressBarsPanel" Margin="0,0,0,10">
                <ProgressBar Height="10" Minimum="0" Maximum="100"></ProgressBar>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
            <Button x:Name="btrStartRace" Content="Старт" Width="80" Margin="0,0,5,0" Click="btrStartRace_Click"/>
        </StackPanel>

        <StackPanel x:Name="p" Margin="0,10,0,0">
            <TextBlock Text="Кінь 1" Width="60"/>
            <ProgressBar x:Name="horse1" Height="10" Margin="0,0,0,10" Minimum="0" Maximum="100"></ProgressBar>
            <TextBlock Text="Кінь 2" Width="60"/>
            <ProgressBar x:Name="horse2" Height="10" Margin="0,0,0,10" Minimum="0" Maximum="100"></ProgressBar>
            <TextBlock Text="Кінь 3" Width="60"/>
            <ProgressBar x:Name="horse3" Height="10" Margin="0,0,0,10" Minimum="0" Maximum="100"></ProgressBar>
            <TextBlock Text="Кінь 4" Width="60"/>
            <ProgressBar x:Name="horse4" Height="10" Margin="0,0,0,10" Minimum="0" Maximum="100"></ProgressBar>
            <TextBlock Text="Кінь 5" Width="60"/>
            <ProgressBar x:Name="horse5" Height="10" Margin="0,0,0,10" Minimum="0" Maximum="100"></ProgressBar>
        </StackPanel>

        <StackPanel>
            <ListBox x:Name="resultsList" Height="110">
                
            </ListBox>
        </StackPanel>
    </StackPanel>
</Window>
